@using System.Globalization

<aside class="summary-panel">
    <div class="summary-heading">
        <span aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
                <path d="M7 2h2v3H7V2Zm4 0h2v3h-2V2Zm4 0h2v3h-2V2ZM5 5h14v16H5V5Zm2 4h10V7H7v2Zm0 4h10v-2H7v2Zm0 4h7v-2H7v2Z" />
            </svg>
        </span>
        <h2>Resumo do Pedido</h2>
    </div>

    <div class="summary-items">
        @if (Items.Count == 0)
        {
            <p class="empty-tray">Selecione os itens para compor o pedido.</p>
        }
        else
        {
            @foreach (var item in Items)
            {
                <div class="summary-item">
                    <span class="summary-item-icon" aria-hidden="true">
                        <FoodIcon Name="@GetIconName(item)" />
                    </span>

                    <strong class="summary-item-name">@item.Name</strong>

                    <strong class="summary-price">@FormatMoney(item.Price)</strong>
                </div>
            }
        }
    </div>

    @if (Items.Count > 0 && DiscountPercent > 0)
    {
        <div class="totals">
            <div>
                <span>Subtotal</span>
                <strong>@FormatMoney(Subtotal)</strong>
            </div>
            <div class="discount-row">
                <span>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12.79 21 3 11.21v2c0 .53.21 1.04.59 1.41l7.79 7.79c.78.78 2.05.78 2.83 0l6.21-6.21c.78-.78.78-2.05 0-2.83L12.79 21zM11.38 17.41c.78.78 2.05.78 2.83 0l6.21-6.21c.78-.78.78-2.05 0-2.83L12.63.57C12.25.19 11.74 0 11.21 0H5C3.9 0 3 .9 3 2v6.21c0 .53.21 1.04.59 1.41l7.79 7.79zM7.5 5C8.33 5 9 5.67 9 6.5S8.33 8 7.5 8 6 7.33 6 6.5 6.67 5 7.5 5z" />
                    </svg>
                    Desconto (@((DiscountPercent * 100).ToString("0"))%)
                </span>
                <strong>- @FormatMoney(Discount)</strong>
            </div>
        </div>
    }

    <div class="summary-total">
        <span>@(DiscountPercent > 0 ? "Total" : "Subtotal")</span>
        <strong>@FormatMoney(Total)</strong>
    </div>

    <div class="summary-actions">
        <button type="button" class="primary-action" disabled="@IsSubmitDisabled" @onclick="Submit">
            @SubmitText
        </button>
        <button type="button" class="secondary-action" disabled="@(Items.Count == 0 || IsBusy)" @onclick="Clear">
            Limpar
        </button>
    </div>
</aside>

@code {
    private static readonly CultureInfo MoneyCulture = CultureInfo.GetCultureInfo("pt-BR");

    [Parameter, EditorRequired]
    public IReadOnlyList<MenuItemViewModel> Items { get; set; } = [];

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Criar Pedido";

    [Parameter, EditorRequired]
    public EventCallback Submitted { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Cleared { get; set; }

    private bool HasSandwich => Items.Any(i => i.Type == MenuItemType.Sandwich);
    private bool HasSide => Items.Any(i => i.Type == MenuItemType.Side);
    private bool HasDrink => Items.Any(i => i.Type == MenuItemType.Drink);

    private decimal DiscountPercent => (HasSandwich, HasSide, HasDrink) switch
    {
        (true, true, true) => 0.20m,
        (true, false, true) => 0.15m,
        (true, true, false) => 0.10m,
        _ => 0m
    };

    private decimal Subtotal => Items.Sum(item => item.Price);
    private decimal Discount => Subtotal * DiscountPercent;
    private decimal Total => Subtotal - Discount;

    private bool IsSubmitDisabled => Items.Count == 0 || IsBusy;

    private Task Submit() => Submitted.InvokeAsync();

    private Task Clear() => Cleared.InvokeAsync();

    private static string GetIconName(MenuItemViewModel item) => item.Type switch
    {
        MenuItemType.Sandwich => "burger",
        MenuItemType.Side => "utensils",
        MenuItemType.Drink => "drink",
        _ => "burger"
    };

    private static string FormatMoney(decimal value) => value.ToString("C2", MoneyCulture);
}
