@using System.Globalization

<article class="summary-card">
    <span class="summary-icon @Tone" aria-hidden="true">
        @if (Icon == "revenue")
        {
            <svg viewBox="0 0 24 24" role="img">
                <path d="M3 6.5h18v11H3v-11Zm2 2v7h14v-7H5Zm4.2 3.5a2.8 2.8 0 1 1 5.6 0 2.8 2.8 0 0 1-5.6 0Zm7.2-1.7h1.4v3.4h-1.4v-3.4ZM6.2 10.3h1.4v3.4H6.2v-3.4Z" />
            </svg>
        }
        else
        {
            <svg viewBox="0 0 24 24" role="img">
                <path d="M6.7 6 6 3.8H3.7V2.2h3.5L8 4.9h12.3l-2 7.1H9.4l.5 1.7h8.3v1.6H8.7L5.1 3.8h1.7L7.2 5H6.7Zm2.2 12.5a1.4 1.4 0 1 1 2.8 0 1.4 1.4 0 0 1-2.8 0Zm7.4 0a1.4 1.4 0 1 1 2.8 0 1.4 1.4 0 0 1-2.8 0Z" />
            </svg>
        }
    </span>

    <div>
        <p>@Label</p>
        <strong>@DisplayValue</strong>
    </div>
</article>

@code {
    private static readonly CultureInfo MoneyCulture = CultureInfo.GetCultureInfo("pt-BR");

    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public decimal Value { get; set; }

    [Parameter]
    public bool IsMoney { get; set; }

    [Parameter]
    public string Icon { get; set; } = "orders";

    [Parameter]
    public string Tone { get; set; } = "cool";

    private string DisplayValue => IsMoney
        ? Value.ToString("C2", MoneyCulture)
        : Value.ToString("N0", CultureInfo.InvariantCulture);
}
